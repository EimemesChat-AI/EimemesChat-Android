<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@drawable/dialog_bg_large"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="32dp"
    android:paddingBottom="24dp"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp">

    <!-- Red icon -->
    <LinearLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:gravity="center"
        android:background="@drawable/signout_icon_bg"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_signout_red"/>

    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign out?"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text1"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <!-- Description -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You\'ll need to sign in again to access your conversations."
        android:textSize="14sp"
        android:textColor="@color/text3"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="24dp"/>

    <!-- Sign out button — red pill -->
    <Button
        android:id="@+id/btnSignOutConfirm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Sign out"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/btn_signout_red"
        android:layout_marginBottom="10dp"/>

    <!-- Cancel button — outline pill -->
    <Button
        android:id="@+id/btnSignOutCancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Cancel"
        android:textSize="15sp"
        android:textColor="@color/text2"
        android:background="@drawable/btn_outline_pill"/>

</LinearLayout>
